{
    "name": "helenofcode-jira-vscode",
    "displayName": "Jira VS Code",
    "description": "Open-source Jira integration for VS Code with reliable authentication for Jira Cloud and custom servers.",
    "version": "1.0.33",
    "publisher": "helenofcode",
    "repository": {
        "type": "git",
        "url": "https://github.com/distrohelena/jira-vscode"
    },
    "engines": {
        "vscode": "^1.85.0"
    },
    "categories": [
        "Other"
    ],
    "galleryBanner": {
        "color": "#0B44C9",
        "theme": "dark"
    },
    "icon": "media/jira.png",
    "keywords": [
        "jira",
        "issues",
        "project",
        "tasks",
        "atlassian",
        "devops",
        "productivity"
    ],
    "activationEvents": [
        "onStartupFinished",
        "onCommand:jira.login",
        "onCommand:jira.focusProject",
        "onCommand:jira.clearProjectFocus",
        "onCommand:jira.openIssueDetails",
        "onCommand:jira.createIssue",
        "onCommand:jira.logout",
        "onCommand:jira.searchCommitHistory",
        "onCommand:jira.validateCredentials",
        "onView:jiraProjectsView",
        "onView:jiraItemsView",
        "onView:jiraNotificationsView",
        "onView:jiraSettingsView"
    ],
    "main": "./dist/extension.js",
    "contributes": {
        "commands": [
            {
                "command": "jira.login",
                "title": "Jira: Log In"
            },
            {
                "command": "jira.focusProject",
                "title": "Jira: Focus Project"
            },
            {
                "command": "jira.validateCredentials",
                "title": "Jira: Validate API Key"
            },
            {
                "command": "jira.clearProjectFocus",
                "title": "Jira: Clear Project Focus"
            },
            {
                "command": "jira.refreshItemsView",
                "title": "ðŸ—˜ Refresh"
            },
            {
                "command": "jira.refreshProjectsView",
                "title": "ðŸ—˜ Refresh Projects"
            },
            {
                "command": "jira.showAllProjects",
                "title": "Show All",
                "category": "Jira"
            },
            {
                "command": "jira.refreshNotificationsView",
                "title": "Refresh Notifications"
            },
            {
                "command": "jira.showRecentProjects",
                "title": "Show Recent",
                "category": "Jira"
            },
            {
                "command": "jira.showFavoriteProjects",
                "title": "Show Favorites",
                "category": "Jira"
            },
            {
                "command": "jira.addProjectFavorite",
                "title": "Favorite Project",
                "category": "Jira"
            },
            {
                "command": "jira.removeProjectFavorite",
                "title": "Remove Favorite",
                "category": "Jira"
            },
            {
                "command": "jira.showAllItems",
                "title": "Show All",
                "category": "Jira"
            },
            {
                "command": "jira.showAssignedItems",
                "title": "Show Assigned",
                "category": "Jira"
            },
            {
                "command": "jira.showUnassignedItems",
                "title": "Show Unassigned",
                "category": "Jira"
            },
            {
                "command": "jira.searchItems",
                "title": "Jira: Filter Items",
                "category": "Jira",
                "icon": "$(filter)"
            },
            {
                "command": "jira.remoteSearchItems",
                "title": "Jira: Search Items",
                "category": "Jira",
                "icon": "$(search)"
            },
            {
                "command": "jira.searchAssignedItems",
                "title": "Jira: Search Assigned Items",
                "category": "Jira",
                "icon": "$(search)"
            },
            {
                "command": "jira.loadMoreItems",
                "title": "Jira: Load More Items",
                "category": "Jira"
            },
            {
                "command": "jira.createIssue",
                "title": "+ Ticket"
            },
            {
                "command": "jira.groupItemsByNone",
                "title": "Group Items: None",
                "category": "Jira"
            },
            {
                "command": "jira.groupItemsByStatus",
                "title": "Group Items: Status",
                "category": "Jira"
            },
            {
                "command": "jira.groupItemsByType",
                "title": "Group Items: Type",
                "category": "Jira"
            },
            {
                "command": "jira.sortItemsByDate",
                "title": "Sort Items: Date",
                "category": "Jira"
            },
            {
                "command": "jira.sortItemsByLastUpdate",
                "title": "Sort Items: Last Update",
                "category": "Jira"
            },
            {
                "command": "jira.sortItemsByAlphabetical",
                "title": "Sort Items: Alphabetically",
                "category": "Jira"
            },
            {
                "command": "jira.openIssueDetails",
                "title": "Jira: Open Issue Details"
            },
            {
                "command": "jira.commitFromIssue",
                "title": "Jira: Commit From Issue",
                "icon": "$(repo-push)"
            },
            {
                "command": "jira.searchCommitHistory",
                "title": "Jira: Search Commit History",
                "icon": "$(git-commit)"
            }
        ],
        "viewsContainers": {
            "activitybar": [
                {
                    "id": "jira",
                    "title": "Jira",
                    "icon": "media/jira.png"
                }
            ]
        },
        "submenus": [
            {
                "id": "jiraItemsGroupBy",
                "label": "Group By"
            },
            {
                "id": "jiraItemsSortBy",
                "label": "Sort By"
            }
        ],
        "menus": {
            "view/title": [
                {
                    "command": "jira.refreshItemsView",
                    "when": "view == jiraItemsView",
                    "group": "navigation"
                },
                {
                    "command": "jira.searchItems",
                    "when": "view == jiraItemsView",
                    "group": "navigation@1"
                },
                {
                    "command": "jira.remoteSearchItems",
                    "when": "view == jiraItemsView",
                    "group": "navigation@1.1"
                },
                {
                    "command": "jira.createIssue",
                    "when": "view == jiraItemsView",
                    "group": "navigation"
                },
                {
                    "command": "jira.showAllItems",
                    "when": "view == jiraItemsView && jiraItemsViewMode == 'assigned'",
                    "group": "navigation@2"
                },
                {
                    "command": "jira.showUnassignedItems",
                    "when": "view == jiraItemsView && jiraItemsViewMode == 'all'",
                    "group": "navigation@2"
                },
                {
                    "command": "jira.showAssignedItems",
                    "when": "view == jiraItemsView && jiraItemsViewMode == 'unassigned'",
                    "group": "navigation@2"
                },
                {
                    "command": "jira.refreshProjectsView",
                    "when": "view == jiraProjectsView",
                    "group": "navigation"
                },
                {
                    "command": "jira.refreshNotificationsView",
                    "when": "view == jiraNotificationsView",
                    "group": "navigation"
                },
                {
                    "command": "jira.showAllProjects",
                    "when": "view == jiraProjectsView && jiraProjectsViewMode == 'recent'",
                    "group": "navigation@2"
                },
                {
                    "command": "jira.showRecentProjects",
                    "when": "view == jiraProjectsView && jiraProjectsViewMode == 'favorites'",
                    "group": "navigation@2"
                },
                {
                    "command": "jira.showFavoriteProjects",
                    "when": "view == jiraProjectsView && jiraProjectsViewMode == 'all'",
                    "group": "navigation@2"
                }
            ],
            "view/item/context": [
                {
                    "command": "jira.commitFromIssue",
                    "when": "view == jiraItemsView && viewItem == jiraIssue",
                    "group": "navigation"
                },
                {
                    "command": "jira.searchCommitHistory",
                    "when": "view == jiraItemsView && viewItem == jiraIssue",
                    "group": "navigation@1"
                },
                {
                    "submenu": "jiraItemsGroupBy",
                    "when": "view == jiraItemsView",
                    "group": "navigation@9"
                },
                {
                    "submenu": "jiraItemsSortBy",
                    "when": "view == jiraItemsView",
                    "group": "navigation@10"
                },
                {
                    "command": "jira.addProjectFavorite",
                    "when": "view == jiraProjectsView && viewItem == jiraProject",
                    "group": "navigation@2"
                },
                {
                    "command": "jira.removeProjectFavorite",
                    "when": "view == jiraProjectsView && viewItem == jiraProjectFavorite",
                    "group": "navigation@2"
                }
            ],
            "jiraItemsGroupBy": [
                {
                    "command": "jira.groupItemsByNone",
                    "when": "view == jiraItemsView",
                    "toggled": "jiraItemsGroupMode == 'none'",
                    "group": "1_none"
                },
                {
                    "command": "jira.groupItemsByStatus",
                    "when": "view == jiraItemsView",
                    "toggled": "jiraItemsGroupMode == 'status'",
                    "group": "2_status"
                },
                {
                    "command": "jira.groupItemsByType",
                    "when": "view == jiraItemsView",
                    "toggled": "jiraItemsGroupMode == 'type'",
                    "group": "3_type"
                }
            ],
            "jiraItemsSortBy": [
                {
                    "command": "jira.sortItemsByDate",
                    "when": "view == jiraItemsView",
                    "toggled": "jiraItemsSortMode == 'date'",
                    "group": "1_date"
                },
                {
                    "command": "jira.sortItemsByLastUpdate",
                    "when": "view == jiraItemsView",
                    "toggled": "jiraItemsSortMode == 'lastUpdate'",
                    "group": "2_lastUpdate"
                },
                {
                    "command": "jira.sortItemsByAlphabetical",
                    "when": "view == jiraItemsView",
                    "toggled": "jiraItemsSortMode == 'alphabetical'",
                    "group": "3_alpha"
                }
            ]
        },
        "views": {
            "jira": [
                {
                    "id": "jiraProjectsView",
                    "name": "Projects"
                },
                {
                    "id": "jiraItemsView",
                    "name": "Items",
                    "icon": "media/items.png"
                },
                {
                    "id": "jiraNotificationsView",
                    "name": "Notifications"
                },
                {
                    "id": "jiraSettingsView",
                    "name": "Settings"
                }
            ]
        },
        "configuration": {
            "title": "Jira",
            "properties": {
                "jira.baseUrl": {
                    "type": "string",
                    "default": "https://your-domain.atlassian.net",
                    "description": "Base URL for your Jira instance (e.g., https://your-domain.atlassian.net)."
                }
            }
        }
    },
    "scripts": {
        "bundle": "node scripts/esbuild.mjs",
        "compile": "npm run bundle",
        "watch": "node scripts/esbuild.mjs --watch",
        "test": "npm run test:node && npm run test:dom && npm run test:smoke",
        "test:node": "node --import tsx --test \"tests/node/**/*.test.ts\"",
        "test:dom": "vitest run --config vitest.config.ts",
        "test:dom:watch": "vitest --config vitest.config.ts",
        "test:smoke": "node --check dist/extension.js",
        "package": "vsce package"
    },
    "devDependencies": {
        "@types/node": "^20.11.0",
        "@types/vscode": "^1.85.0",
        "esbuild": "^0.27.0",
        "jsdom": "^26.1.0",
        "tsx": "^4.20.5",
        "typescript": "^5.3.3",
        "vitest": "^3.2.4"
    },
    "dependencies": {
        "@tiptap/core": "^3.22.3",
        "@tiptap/extension-link": "^3.22.3",
        "@tiptap/extension-underline": "^3.22.3",
        "@tiptap/starter-kit": "^3.22.3",
        "axios": "^1.6.2",
        "rollup": "^4.60.1"
    }
}
